{
  "name": "coding-agent-lite",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Clean-room minimal coding agent with a web chat UI, tool-use loop, workspace sandbox, and trace viewer.",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsx --test test/*.test.ts",
    "reset-demo": "node scripts/reset-demo.mjs",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "ai": "^6.0.208",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
